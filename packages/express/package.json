{
  "name": "@limitlayer/express",
  "version": "0.1.0-alpha.0",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "description": "Official Express adapter for LimitLayer",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@limitlayer/core": "workspace:*"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/supertest": "^7.2.0",
    "express": "^5.2.1",
    "supertest": "^7.2.2"
  },
  "homepage": "https://github.com/limitlayer/limitlayer#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/limitlayer/limitlayer.git"
  },
  "bugs": {
    "url": "https://github.com/limitlayer/limitlayer/issues"
  },
  "keywords": [
    "rate-limit",
    "rate-limiter",
    "express",
    "typescript",
    "nodejs",
    "middleware",
    "api",
    "backend"
  ],
   "license": "MIT"
}