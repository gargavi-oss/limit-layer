{
  "name": "@limitlayer/core",
  "version": "0.2.0-alpha.3",
  "private": false,
  "description": "Framework-agnostic rate limiting engine for Node.js and TypeScript supporting Fixed Window, Sliding Window, Token Bucket, Sliding Log, Leaky Bucket, MemoryStore, and RedisStore.",
  "license": "MIT",
  "type": "module",

  "publishConfig": {
    "access": "public"
  },

  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",

  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },

  "files": [
    "dist"
  ],

  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist"
  },

  "homepage": "https://github.com/gargavi-oss/limit-layer",

  "repository": {
    "type": "git",
    "url": "git+https://github.com/gargavi-oss/limit-layer.git"
  },

  "bugs": {
    "url": "https://github.com/gargavi-oss/limit-layer/issues"
  },

  "keywords": [
    "limitlayer",
    "limit-layer",
    "rate-limit",
    "rate-limiter",
    "rate-limiting",
    "nodejs",
    "typescript",
    "backend",
    "api",
    "rest-api",
    "security",
    "middleware",
    "fixed-window",
    "sliding-window",
    "token-bucket",
    "sliding-log",
    "leaky-bucket",
    "memory-store",
    "redis",
    "redis-store",
    "distributed-rate-limit"
  ],

  "dependencies": {
    "redis": "^6.1.0"
  }
}